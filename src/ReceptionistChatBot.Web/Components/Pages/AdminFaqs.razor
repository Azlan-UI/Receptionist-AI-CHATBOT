@page "/admin/faqs"
@inject FaqApiClient FaqApiClient
@attribute [Layout(typeof(Layout.AdminLayout))]

<PageTitle>Manage FAQs</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">FAQs</h2>
        <p class="text-body-secondary mb-0 small">Manage knowledge base questions and answers</p>
    </div>
    <button class="btn btn-primary" @onclick="ShowCreateForm">
        <span class="d-flex align-items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2"/>
            </svg>
            New FAQ
        </span>
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_isLoading)
{
    <LoadingSpinner Text="Loading FAQs" />
}
else if (_faqs.Count == 0)
{
    <div class="text-center py-5 text-body-secondary">
        <p class="mb-0">No FAQs yet. Create your first one.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th class="d-none d-md-table-cell">Order</th>
                    <th>Question</th>
                    <th class="d-none d-md-table-cell">Category</th>
                    <th class="d-none d-sm-table-cell">Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var faq in _faqs.OrderBy(f => f.DisplayOrder).ThenBy(f => f.Question))
                {
                    <tr>
                        <td class="d-none d-md-table-cell text-body-secondary">@faq.DisplayOrder</td>
                        <td>
                            <div class="fw-medium">@faq.Question</div>
                            <div class="small text-body-secondary text-truncate" style="max-width: 400px;">@faq.Answer</div>
                        </td>
                        <td class="d-none d-md-table-cell"><span class="badge text-bg-light">@faq.Category</span></td>
                        <td class="d-none d-sm-table-cell">
                            <span class="badge @(faq.IsActive ? "text-bg-success" : "text-bg-secondary")">
                                @(faq.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-outline-primary btn-sm" @onclick="() => ShowEditForm(faq)" title="Edit">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"/>
                                    </svg>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(faq)" title="Delete">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Create/Edit Modal ── *@
@if (_showForm)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5">@(_isEditing ? "Edit FAQ" : "Create FAQ")</h3>
                    <button type="button" class="btn-close" @onclick="CancelForm"></button>
                </div>
                <EditForm Model="_formModel" OnValidSubmit="SaveFaqAsync" FormName="faqForm">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label" for="question">Question</label>
                            <InputText id="question" class="form-control" @bind-Value="_formModel.Question" />
                            <ValidationMessage For="() => _formModel.Question" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="answer">Answer</label>
                            <InputTextArea id="answer" class="form-control" rows="4" @bind-Value="_formModel.Answer" />
                            <ValidationMessage For="() => _formModel.Answer" class="text-danger small" />
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label" for="category">Category</label>
                                <InputText id="category" class="form-control" @bind-Value="_formModel.Category" />
                                <ValidationMessage For="() => _formModel.Category" class="text-danger small" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="keywords">Keywords</label>
                                <InputText id="keywords" class="form-control" @bind-Value="_formModel.Keywords" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label" for="displayOrder">Display Order</label>
                                <InputNumber id="displayOrder" class="form-control" @bind-Value="_formModel.DisplayOrder" />
                                <ValidationMessage For="() => _formModel.DisplayOrder" class="text-danger small" />
                            </div>
                            <div class="col-md-2 d-flex align-items-end pb-1">
                                <div class="form-check">
                                    <InputCheckbox id="isActive" class="form-check-input" @bind-Value="_formModel.IsActive" />
                                    <label class="form-check-label" for="isActive">Active</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            @(_isEditing ? "Update" : "Create")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ── Delete Confirmation Modal ── *@
@if (_deleteTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title h5">Delete FAQ</h3>
                    <button type="button" class="btn-close" @onclick="() => _deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this FAQ?</p>
                    <p class="fw-medium mb-0">@_deleteTarget.Question</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _deleteTarget = null">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteFaqAsync" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FaqDto> _faqs = [];
    private FaqFormModel _formModel = new();
    private FaqDto? _deleteTarget;
    private bool _isLoading;
    private bool _isSaving;
    private bool _showForm;
    private bool _isEditing;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadFaqsAsync();
    }

    private async Task LoadFaqsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _faqs = [.. await FaqApiClient.GetAllAsync()];
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load FAQs: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowCreateForm()
    {
        _formModel = new FaqFormModel();
        _isEditing = false;
        _showForm = true;
    }

    private void ShowEditForm(FaqDto faq)
    {
        _formModel = new FaqFormModel
        {
            Question = faq.Question,
            Answer = faq.Answer,
            Category = faq.Category,
            Keywords = faq.Keywords ?? string.Empty,
            DisplayOrder = faq.DisplayOrder,
            IsActive = faq.IsActive
        };
        _editingId = faq.Id;
        _isEditing = true;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _isEditing = false;
        _editingId = null;
    }

    private async Task SaveFaqAsync()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            if (_isEditing && _editingId.HasValue)
            {
                var request = new UpdateFaqRequest(
                    _formModel.Question,
                    _formModel.Answer,
                    _formModel.Category,
                    string.IsNullOrWhiteSpace(_formModel.Keywords) ? null : _formModel.Keywords,
                    _formModel.DisplayOrder,
                    _formModel.IsActive);

                await FaqApiClient.UpdateAsync(_editingId.Value, request);
            }
            else
            {
                var request = new CreateFaqRequest(
                    _formModel.Question,
                    _formModel.Answer,
                    _formModel.Category,
                    string.IsNullOrWhiteSpace(_formModel.Keywords) ? null : _formModel.Keywords,
                    _formModel.DisplayOrder,
                    _formModel.IsActive);

                await FaqApiClient.CreateAsync(request);
            }

            CancelForm();
            await LoadFaqsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save FAQ: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ConfirmDelete(FaqDto faq)
    {
        _deleteTarget = faq;
    }

    private async Task DeleteFaqAsync()
    {
        if (_deleteTarget is null) return;

        _isSaving = true;
        _errorMessage = null;

        try
        {
            await FaqApiClient.DeleteAsync(_deleteTarget.Id);
            _deleteTarget = null;
            await LoadFaqsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete FAQ: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Guid? _editingId;

    private sealed class FaqFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Question is required")]
        [System.ComponentModel.DataAnnotations.StringLength(500)]
        public string Question { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Answer is required")]
        [System.ComponentModel.DataAnnotations.StringLength(4000)]
        public string Answer { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Category is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100)]
        public string Category { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.StringLength(500)]
        public string? Keywords { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0, 10000)]
        public int DisplayOrder { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
