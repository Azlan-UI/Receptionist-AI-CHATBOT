@{
    var isUser = Message.Role == MessageRole.User;
    var roleLabel = isUser ? "You" : "Assistant";
}

<div class="message-row @(isUser ? "user" : "assistant")">
    <div class="message-bubble @(isUser ? "user" : "assistant")">
        <div class="message-label">@roleLabel</div>
        <div class="message-text">@Message.Content</div>
        <div class="message-time">@Message.CreatedAtUtc.ToLocalTime().ToString("t")</div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ChatMessageDto Message { get; set; } = null!;
}
