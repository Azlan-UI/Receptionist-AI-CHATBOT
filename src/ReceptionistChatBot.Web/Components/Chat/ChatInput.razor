@inject IJSRuntime JSRuntime

<div class="chat-input-area">
    <div class="chat-input-wrapper">
        <input @ref="_inputRef"
               class="form-control"
               placeholder="Type your message..."
               @bind-value="_model.Message"
               @bind-value:event="oninput"
               disabled="@IsDisabled"
               @onkeydown="HandleKeyDown" />
        <button class="btn-send" type="button" @onclick="SubmitAsync" disabled="@(IsDisabled || string.IsNullOrWhiteSpace(_model.Message))" title="Send message">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z"/>
            </svg>
        </button>
    </div>
</div>

@code {
    private readonly ChatInputModel _model = new();
    private ElementReference _inputRef;

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public EventCallback<string> OnSend { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !IsDisabled)
        {
            await FocusInputAsync();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SubmitAsync();
        }
    }

    private async Task SubmitAsync()
    {
        var message = _model.Message?.Trim();

        if (string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        _model.Message = string.Empty;
        await OnSend.InvokeAsync(message);
    }

    public async Task FocusInputAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("receptionistChat.focusInput", _inputRef.Id);
        }
        catch
        {
        }
    }

    private sealed class ChatInputModel
    {
        public string Message { get; set; } = string.Empty;
    }
}
